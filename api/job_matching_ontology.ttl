ex:hasApplicantType a owl:DatatypeProperty ;
    rdfs:label "has applicant type" ;
    rdfs:comment "The category of the applicant, e.g. 'Fresh Graduate' or 'IT Student'." ;
    rdfs:domain ex:Applicant ;
    rdfs:range xsd:string .

ex:hasDegreeLevel a owl:DatatypeProperty ;
    rdfs:label "has degree level" ;
    rdfs:comment "The level of the degree: Bachelor, Diploma, etc." ;
    rdfs:domain ex:Education ;
    rdfs:range xsd:string .

ex:hasDegreeName a owl:DatatypeProperty ;
    rdfs:label "has degree name" ;
    rdfs:comment "The name or title of the degree, e.g. 'BSc Computer Science'." ;
    rdfs:domain ex:Education ;
    rdfs:range xsd:string .

ex:hasDurationMonths a owl:DatatypeProperty ;
    rdfs:label "has duration (months)" ;
    rdfs:comment "Duration of the experience in months." ;
    rdfs:domain ex:Experience ;
    rdfs:range xsd:integer .

ex:hasEducation a owl:ObjectProperty ;
    rdfs:label "has education" ;
    rdfs:comment "Links an applicant to their educational qualification." ;
    rdfs:domain ex:Applicant ;
    rdfs:range ex:Education .

ex:hasExperience a owl:ObjectProperty ;
    rdfs:label "has experience" ;
    rdfs:comment "Links an applicant to a work or internship experience." ;
    rdfs:domain ex:Applicant ;
    rdfs:range ex:Experience .

ex:hasExperienceType a owl:DatatypeProperty ;
    rdfs:label "has experience type" ;
    rdfs:comment "The type of experience, e.g. 'Internship', 'Part-time', 'Freelance'." ;
    rdfs:domain ex:Experience ;
    rdfs:range xsd:string .

ex:hasFieldOfStudy a owl:DatatypeProperty ;
    rdfs:label "has field of study" ;
    rdfs:comment "The specialisation or field of the degree." ;
    rdfs:domain ex:Education ;
    rdfs:range xsd:string .

ex:hasGraduationYear a owl:DatatypeProperty ;
    rdfs:label "has graduation year" ;
    rdfs:comment "The year the applicant graduated or expects to graduate." ;
    rdfs:domain ex:Education ;
    rdfs:range xsd:integer .

ex:hasIndustry a owl:DatatypeProperty ;
    rdfs:label "has industry" ;
    rdfs:comment "The industry sector of the company." ;
    rdfs:domain ex:Company ;
    rdfs:range xsd:string .

ex:hasInstitution a owl:DatatypeProperty ;
    rdfs:label "has institution" ;
    rdfs:comment "The university or institution that awarded the qualification." ;
    rdfs:domain ex:Education ;
    rdfs:range xsd:string .

ex:hasJobLevel a owl:DatatypeProperty ;
    rdfs:label "has job level" ;
    rdfs:comment "Seniority level of the position, e.g. 'Entry-Level', 'Junior'." ;
    rdfs:domain ex:Job ;
    rdfs:range xsd:string .

ex:hasLocation a owl:DatatypeProperty ;
    rdfs:label "has location" ;
    rdfs:comment "The headquarters or office location of the company." ;
    rdfs:domain ex:Company ;
    rdfs:range xsd:string .

ex:hasName a owl:DatatypeProperty ;
    rdfs:label "has name" ;
    rdfs:comment "The full name of the applicant." ;
    rdfs:domain ex:Applicant ;
    rdfs:range xsd:string .

ex:hasOrganisation a owl:DatatypeProperty ;
    rdfs:label "has organisation" ;
    rdfs:comment "The organisation where the experience took place." ;
    rdfs:domain ex:Experience ;
    rdfs:range xsd:string .

ex:hasRequiredDegreeLevel a owl:DatatypeProperty ;
    rdfs:label "has required degree level" ;
    rdfs:comment "The minimum education level required by this job." ;
    rdfs:domain ex:Job ;
    rdfs:range xsd:string .

ex:hasRole a owl:DatatypeProperty ;
    rdfs:label "has role" ;
    rdfs:comment "The job title or role held during the experience." ;
    rdfs:domain ex:Experience ;
    rdfs:range xsd:string .

ex:hasSkill a owl:ObjectProperty ;
    rdfs:label "has skill" ;
    rdfs:comment "Links an applicant to a skill they possess." ;
    rdfs:domain ex:Applicant ;
    rdfs:range ex:Skill .

ex:offersJob a owl:ObjectProperty ;
    rdfs:label "offers job" ;
    rdfs:comment "Associates a company with a job position it offers (inverse of offeredBy)." ;
    rdfs:domain ex:Company ;
    rdfs:range ex:Job ;
    owl:inverseOf ex:offeredBy .

ex:requiresCoreSkill a owl:ObjectProperty ;
    rdfs:label "requires core skill" ;
    rdfs:comment "Links a job to a core skill it requires." ;
    rdfs:domain ex:Job ;
    rdfs:range ex:Skill ;
    rdfs:subPropertyOf ex:requiresSkill .

