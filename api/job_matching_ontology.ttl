@prefix ex:   <http://example.org/jobmatch#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# =============================================================
#  ONTOLOGY DECLARATION
# =============================================================
ex:JobMatchingOntology rdf:type owl:Ontology ;
    rdfs:label "Smart Job Matching Ontology for IT Graduates" ;
    rdfs:comment "An OWL ontology that models IT job positions, applicant profiles, skills, education, and experience to enable semantic job matching for IT students and fresh graduates." .

# =============================================================
#  CLASSES
# =============================================================
ex:Applicant rdf:type owl:Class ;
    rdfs:label "Applicant" ;
    rdfs:comment "A person seeking employment — either an IT student or a fresh graduate." .

ex:Job rdf:type owl:Class ;
    rdfs:label "Job" ;
    rdfs:comment "An IT job position offered by a company." .

ex:Skill rdf:type owl:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "A technical competency relevant to IT positions." .

ex:Company rdf:type owl:Class ;
    rdfs:label "Company" ;
    rdfs:comment "An organisation that offers job positions." .

ex:Education rdf:type owl:Class ;
    rdfs:label "Education" ;
    rdfs:comment "An educational qualification held by an applicant." .

ex:Experience rdf:type owl:Class ;
    rdfs:label "Experience" ;
    rdfs:comment "A work or internship experience record held by an applicant." .

# ---------- Skill Sub-categories (RDFS subClassOf) ----------
ex:ProgrammingLanguage rdf:type owl:Class ;
    rdfs:subClassOf ex:Skill ;
    rdfs:label "Programming Language" ;
    rdfs:comment "A programming, scripting, or markup language." .

ex:AIDataSkill rdf:type owl:Class ;
    rdfs:subClassOf ex:Skill ;
    rdfs:label "AI and Data Science Skill" ;
    rdfs:comment "A skill related to artificial intelligence, machine learning, or data science." .

ex:WebCloudSkill rdf:type owl:Class ;
    rdfs:subClassOf ex:Skill ;
    rdfs:label "Web and Cloud Technology Skill" ;
    rdfs:comment "A skill related to web development frameworks or cloud platforms." .

ex:SecuritySkill rdf:type owl:Class ;
    rdfs:subClassOf ex:Skill ;
    rdfs:label "Cybersecurity Skill" ;
    rdfs:comment "A skill related to information security and penetration testing." .

ex:DevToolSkill rdf:type owl:Class ;
    rdfs:subClassOf ex:Skill ;
    rdfs:label "Development Tool Skill" ;
    rdfs:comment "A skill related to version control, CI/CD, or DevOps tooling." .

# ---------- OWL Disjoint-Class Axioms ----------
ex:Applicant owl:disjointWith ex:Job .
ex:Applicant owl:disjointWith ex:Company .
ex:Applicant owl:disjointWith ex:Skill .
ex:Job       owl:disjointWith ex:Company .
ex:Job       owl:disjointWith ex:Skill .
ex:Company   owl:disjointWith ex:Skill .

# =============================================================
#  OBJECT PROPERTIES
# =============================================================
ex:hasSkill rdf:type owl:ObjectProperty ;
    rdfs:domain ex:Applicant ;
    rdfs:range  ex:Skill ;
    rdfs:label  "has skill" ;
    rdfs:comment "Links an applicant to a skill they possess." .

ex:requiresSkill rdf:type owl:ObjectProperty ;
    rdfs:domain ex:Job ;
    rdfs:range  ex:Skill ;
    rdfs:label  "requires skill" ;
    rdfs:comment "Links a job to a skill it requires from candidates." .

ex:hasEducation rdf:type owl:ObjectProperty ;
    rdfs:domain ex:Applicant ;
    rdfs:range  ex:Education ;
    rdfs:label  "has education" ;
    rdfs:comment "Links an applicant to their educational qualification." .

ex:hasExperience rdf:type owl:ObjectProperty ;
    rdfs:domain ex:Applicant ;
    rdfs:range  ex:Experience ;
    rdfs:label  "has experience" ;
    rdfs:comment "Links an applicant to a work or internship experience." .

ex:offeredBy rdf:type owl:ObjectProperty ;
    rdfs:domain ex:Job ;
    rdfs:range  ex:Company ;
    rdfs:label  "offered by" ;
    rdfs:comment "Associates a job position with the company that offers it." .

ex:offersJob rdf:type owl:ObjectProperty ;
    owl:inverseOf ex:offeredBy ;
    rdfs:domain ex:Company ;
    rdfs:range  ex:Job ;
    rdfs:label  "offers job" ;
    rdfs:comment "Associates a company with a job position it offers (inverse of offeredBy)." .

# ---------- Functional-Property Axiom ----------
# Each job is offered by exactly one company.
ex:offeredBy rdf:type owl:FunctionalProperty .

# =============================================================
#  DATATYPE PROPERTIES
# =============================================================
ex:hasName rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Applicant ;
    rdfs:range  xsd:string ;
    rdfs:label  "has name" ;
    rdfs:comment "The full name of the applicant." .

ex:hasApplicantType rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Applicant ;
    rdfs:range  xsd:string ;
    rdfs:label  "has applicant type" ;
    rdfs:comment "The category of the applicant, e.g. 'Fresh Graduate' or 'IT Student'." .

ex:hasDegreeName rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Education ;
    rdfs:range  xsd:string ;
    rdfs:label  "has degree name" ;
    rdfs:comment "The name or title of the degree, e.g. 'BSc Computer Science'." .

ex:hasDegreeLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Education ;
    rdfs:range  xsd:string ;
    rdfs:label  "has degree level" ;
    rdfs:comment "The level of the degree: Bachelor, Diploma, etc." .

ex:hasFieldOfStudy rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Education ;
    rdfs:range  xsd:string ;
    rdfs:label  "has field of study" ;
    rdfs:comment "The specialisation or field of the degree." .

ex:hasInstitution rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Education ;
    rdfs:range  xsd:string ;
    rdfs:label  "has institution" ;
    rdfs:comment "The university or institution that awarded the qualification." .

ex:hasGraduationYear rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Education ;
    rdfs:range  xsd:integer ;
    rdfs:label  "has graduation year" ;
    rdfs:comment "The year the applicant graduated or expects to graduate." .

ex:hasRole rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Experience ;
    rdfs:range  xsd:string ;
    rdfs:label  "has role" ;
    rdfs:comment "The job title or role held during the experience." .

ex:hasOrganisation rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Experience ;
    rdfs:range  xsd:string ;
    rdfs:label  "has organisation" ;
    rdfs:comment "The organisation where the experience took place." .

ex:hasDurationMonths rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Experience ;
    rdfs:range  xsd:integer ;
    rdfs:label  "has duration (months)" ;
    rdfs:comment "Duration of the experience in months." .

ex:hasExperienceType rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Experience ;
    rdfs:range  xsd:string ;
    rdfs:label  "has experience type" ;
    rdfs:comment "The type of experience, e.g. 'Internship', 'Part-time', 'Freelance'." .

ex:hasJobLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Job ;
    rdfs:range  xsd:string ;
    rdfs:label  "has job level" ;
    rdfs:comment "Seniority level of the position, e.g. 'Entry-Level', 'Junior'." .

ex:hasRequiredDegreeLevel rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Job ;
    rdfs:range  xsd:string ;
    rdfs:label  "has required degree level" ;
    rdfs:comment "The minimum education level required by this job." .

ex:hasLocation rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Company ;
    rdfs:range  xsd:string ;
    rdfs:label  "has location" ;
    rdfs:comment "The headquarters or office location of the company." .

ex:hasIndustry rdf:type owl:DatatypeProperty ;
    rdfs:domain ex:Company ;
    rdfs:range  xsd:string ;
    rdfs:label  "has industry" ;
    rdfs:comment "The industry sector of the company." .

# =============================================================
#  INSTANCES — SKILLS  (22 skills)
# =============================================================

# ---- Programming Languages (7) ----
ex:Python rdf:type ex:ProgrammingLanguage ;
    rdfs:label "Python" .

ex:Java rdf:type ex:ProgrammingLanguage ;
    rdfs:label "Java" .

ex:JavaScript rdf:type ex:ProgrammingLanguage ;
    rdfs:label "JavaScript" .

ex:HTML rdf:type ex:ProgrammingLanguage ;
    rdfs:label "HTML" .

ex:CSS rdf:type ex:ProgrammingLanguage ;
    rdfs:label "CSS" .

ex:SQL rdf:type ex:ProgrammingLanguage ;
    rdfs:label "SQL" .

ex:NoSQL rdf:type ex:ProgrammingLanguage ;
    rdfs:label "NoSQL" .

# ---- AI / Data Science (5) ----
ex:MachineLearning rdf:type ex:AIDataSkill ;
    rdfs:label "Machine Learning" .

ex:DeepLearning rdf:type ex:AIDataSkill ;
    rdfs:label "Deep Learning" .

ex:HuggingFace rdf:type ex:AIDataSkill ;
    rdfs:label "Hugging Face" .

ex:NLP rdf:type ex:AIDataSkill ;
    rdfs:label "Natural Language Processing" .

ex:DataAnalysis rdf:type ex:AIDataSkill ;
    rdfs:label "Data Analysis" .

# ---- Web / Cloud (5) ----
ex:React rdf:type ex:WebCloudSkill ;
    rdfs:label "React" .

ex:NodeJS rdf:type ex:WebCloudSkill ;
    rdfs:label "Node.js" .

ex:CloudComputingAWS rdf:type ex:WebCloudSkill ;
    rdfs:label "Cloud Computing (AWS)" .

ex:Docker rdf:type ex:WebCloudSkill ;
    rdfs:label "Docker" .

ex:Kubernetes rdf:type ex:WebCloudSkill ;
    rdfs:label "Kubernetes" .

# ---- Security (2) ----
ex:Cybersecurity rdf:type ex:SecuritySkill ;
    rdfs:label "Cybersecurity" .

ex:PenetrationTesting rdf:type ex:SecuritySkill ;
    rdfs:label "Penetration Testing" .

# ---- Dev Tools (3) ----
ex:APIIntegration rdf:type ex:DevToolSkill ;
    rdfs:label "API Integration" .

ex:Git rdf:type ex:DevToolSkill ;
    rdfs:label "Git" .

ex:GitHub rdf:type ex:DevToolSkill ;
    rdfs:label "GitHub" .

# =============================================================
